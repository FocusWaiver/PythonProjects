def report(duration, start_date):
    duroAdd = 0
    end_date = int(start_date)-int(duration)
    with open("TimeTrackerTotalDurationLog.txt") as td_log:
        for entry in (td_log.readlines()):
            entry_split = entry.split("/")
            if int(entry_split[0]) >= end_date:
                duroAdd += int(entry_split[1])
        print("Over the last ",duration,"days, you've studied", duroAdd, "seconds.")





