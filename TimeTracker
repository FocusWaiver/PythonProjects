            print("You studied for ", dif_sec, "seconds.")
        elif dif_sec <= 3600:
            p_min = int(round(dif_sec/60))
            print("You studied for about ",p_min,"minutes")
        else:
            float_hour = dif_sec/3600
            p_hour = int(math.floor(dif_sec/3600))
            p_min = int(math.floor((float_hour-p_hour)*60))
            float_min = (float_hour-p_hour)*60
            p_sec = int(round((float_min-p_min)*60))
            print(float_hour,p_hour,p_min,float_min,p_sec)
            print("You studied for ",p_hour,"hours, ",p_min,"minutes, and ",p_sec,"seconds")



    #open save file for log of total session duration
    sess = open("TimeTrackerTotalDurationLog.txt", "a")
    total_entry = str(y_day)+"/"+str(dif_sec)
