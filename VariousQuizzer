def scoreMessage(score, count):
    if score / count == 0:
        print("Ouch! Maybe you'll get one next time")
    elif score / count < 0.3:
        print("Hmm, better luck next time.")
    elif score / count < 0.7:
        print("Not too bad, but there is room for improvement.")
    elif count - score == 1:
        print("Nice Job! One off from perfect!")
    elif count == score:
        print("Perfect Score! Fantastic Job!")
    else:
        print("Good Job!  Your percentage was ", round(score / count, 2))
    print("You scored ", score, "/", count, "\n", "Goodbye!")

#check input when floats are required
def numberAns(count):
    raw = input()
    try:
        user = float(raw)
    except:
        if raw != "quit":
            print("*Error: input unable to be a float*\n")
            count -= 1
        user = raw
    return count, user, raw


# km to mi, option 1
def kmi():
    r = random.randint(1, 20)
    i = int(r * 5)
    print('How many miles is ', i, 'km?')
    ans = round(i * (0.621371),1)
    return ans

# C to F, option 2
def c_to_f():
    c = random.randint(-8, 20)
    j = int(c * 5)
    print("What is ", j, "C, in F?")
    ans_c = round(j * (9 / 5) + 32,0)
    print(ans_c)
    return ans_c

